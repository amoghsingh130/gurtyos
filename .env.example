# Copy to .env and fill in. Never commit .env.

# Slack — internal app in a Developer Program sandbox (Socket Mode)
SLACK_BOT_TOKEN=xoxb-...        # Bot User OAuth Token
SLACK_APP_TOKEN=xapp-...        # App-Level Token with connections:write (Socket Mode)

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Spend guardrails (app-side backstop; also set a hard spend limit in the console).
# Refuse LLM calls once cumulative estimated spend hits this many USD:
MAX_SPEND_USD=8.0
# Per-day call cap across all flows — catches a runaway loop:
MAX_CALLS_PER_DAY=300
