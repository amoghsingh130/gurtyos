# Copy to .env and fill in. Never commit .env.

# Slack — internal app in a Developer Program sandbox (Socket Mode)
SLACK_BOT_TOKEN=xoxb-...        # Bot User OAuth Token
SLACK_APP_TOKEN=xapp-...        # App-Level Token with connections:write (Socket Mode)

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Spend guardrails (app-side backstop; also set a hard spend limit in the console).
# Refuse LLM calls once cumulative estimated spend hits this many USD:
MAX_SPEND_USD=8.0
# Per-day call cap across all flows — catches a runaway loop:
MAX_CALLS_PER_DAY=300

# Models (override the code defaults). Digest defaults to Sonnet 4.6 — fast and on a
# separate capacity pool from Opus (fewer 529 "overloaded" errors). Set the digest to
# claude-opus-4-8 for the final recorded demo if you want maximum polish.
# MODEL_DIGEST=claude-opus-4-8
# MODEL_REWRITE=claude-haiku-4-5
# MODEL_ALT_TEXT=claude-haiku-4-5
# Retries for transient Anthropic 529s (the SDK backs off between attempts):
ANTHROPIC_MAX_RETRIES=5

# Proactive plain-language offer (the autonomy beat): the agent watches these
# channels and, on its own, offers to post a plain-language version of hard-to-read
# threads. Comma-separated channel IDs; leave empty to disable. Scoped on purpose so
# the agent never nudges a real workspace it wasn't invited to.
DEMO_CHANNELS=
# Reading-grade ceiling above which a (punctuated) thread is offered a rewrite:
REWRITE_OFFER_GRADE=12.0
